# Sao chép thành file .env và điền giá trị. File .env không commit (đã có trong .gitignore).
# Biến OS (export / System Properties) được ưu tiên hơn nội dung .env.

# MySQL
MYSQL_URL=jdbc:mysql://localhost:3306/bookverse
MYSQL_USERNAME=root
MYSQL_PASSWORD=

# JWT (HS256) — chuỗi Base64
BOOKVERSE_JWT_BASE64_SECRET=
BOOKVERSE_JWT_ACCESS_TOKEN_VALIDITY=100000
BOOKVERSE_JWT_REFRESH_TOKEN_VALIDITY=864000

# Thư mục upload (URI dạng file:)
BOOKVERSE_UPLOAD_BASE_URI=file:///D:/path/to/upload_bookverse/

# VNPay (sandbox / production)
BOOKVERSE_VNPAY_TMN_CODE=
BOOKVERSE_VNPAY_HASH_SECRET=
BOOKVERSE_VNPAY_PAYMENT_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
BOOKVERSE_VNPAY_RETURN_URL=http://localhost:8080/api/v1/payments/vnpay/return
BOOKVERSE_VNPAY_FRONTEND_SUCCESS_URL=http://localhost:5173/payment/success
BOOKVERSE_VNPAY_FRONTEND_FAIL_URL=http://localhost:5173/payment/failure

# Mail (bật khi cần)
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=
# MAIL_PASSWORD=
